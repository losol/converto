{
  "name": "@eventuras/convertoapi",
  "version": "2.0.0",
  "description": "generates pdfs",
  "license": "MIT",
  "author": {
    "name": "Losol AS"
  },
  "maintainers": [
    {
      "name": "Ole Kristian Losvik"
    },
    {
      "name": "M.A. van't Kruis (hellomeinte.com)"
    }
  ],
  "type": "module",
  "main": "dist/app.js",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc && cp -R public dist",
    "dev": "tsx src/app.ts",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude src/integration.test.ts",
    "test:integration": "vitest run src/integration.test.ts",
    "test:e2e": "bash tests/e2e/smoke-docker.sh",
    "test:coverage": "vitest run --coverage --exclude src/integration.test.ts",
    "test:watch": "vitest --exclude src/integration.test.ts",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "prettier": {
    "trailingComma": "es5",
    "semi": true,
    "singleQuote": true,
    "arrowParens": "avoid",
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "endOfLine": "auto"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.62.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "fastify-plugin": "^6.0.0",
    "playwright": "^1.61.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-only-warn": "^1.2.1",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
